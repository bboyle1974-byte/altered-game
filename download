}
function IconStar({ size = 28 }) {
  return (
    <div style={{ width:size, height:size, borderRadius:size*0.25, background:C.yellow,
      display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
      <svg width={size*0.58} height={size*0.58} viewBox="0 0 24 24" fill="none">
        <path d="M12 2l3 6 7 1-5 5 1 7-6-3-6 3 1-7L2 9l7-1 3-6z" fill={C.ink} fillOpacity="0.85"/>
