// ─── Helpers ──────────────────────────────────────────────────────────────────
function scramble(word) {
  let arr = word.split(""), tries = 0;
  do {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    tries++;
  } while (arr.join("") === word && tries < 20);
  return arr.join("");
}
function getDailyWord(diff) {
  // Use local date to avoid UTC midnight boundary issues
  const d = new Date();
  const dayNum = d.getFullYear() * 10000 + (d.getMonth()+1) * 100 + d.getDate();
  // Use a simple hash of the day number for consistent ordering
  const idx = ((dayNum * 2654435761) >>> 0) % WORDS[diff].length;
  return WORDS[diff][idx];
}
function getDayKey() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
}
