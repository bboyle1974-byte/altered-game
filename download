// ─── ClockRing ────────────────────────────────────────────────────────────────
function ClockRing({ timeLeft, total }) {
  const r = 42, circ = 2 * Math.PI * r;
  const pct = timeLeft / total;
  const color = timeLeft > total*0.4 ? C.teal : timeLeft > total*0.2 ? C.yellow : C.coral;
  return (
    <svg width={106} height={106} viewBox="0 0 106 106">
      <circle cx={53} cy={53} r={r} fill="none" stroke={C.border} strokeWidth={8}/>
      <circle cx={53} cy={53} r={r} fill="none" stroke={color} strokeWidth={8}
        strokeDasharray={circ} strokeDashoffset={circ*(1-pct)}
        strokeLinecap="round" transform="rotate(-90 53 53)"
        style={{ transition:"stroke-dashoffset 0.25s linear, stroke 0.4s" }}
      />
      <text x={53} y={60} textAnchor="middle" fill={color}
        fontSize={28} fontWeight={900} fontFamily="'Helvetica Neue', Helvetica, Arial, sans-serif">{timeLeft}</text>
    </svg>
  );
}


