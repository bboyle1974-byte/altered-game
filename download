  );
}


// ─── Confetti celebration ─────────────────────────────────────────────────────
function Confetti({ active }) {
  if (!active) return null;
  const pieces = Array.from({ length: 32 }, (_, i) => ({
    id: i,
    x: Math.random() * 100,
    delay: Math.random() * 0.6,
    dur: 1.2 + Math.random() * 0.8,
    size: 7 + Math.random() * 8,
    color: [C.teal, C.coral, C.yellow, LOGO_GREEN, "#fff"][i % 5],
    rotate: Math.random() * 360,
    drift: (Math.random() - 0.5) * 60,
  }));
  return (
    <div style={{
      position:"fixed", top:0, left:0, width:"100%", height:"100%",
      pointerEvents:"none", zIndex:999, overflow:"hidden",
    }}>
      {pieces.map(p => (
        <div key={p.id} style={{
          position:"absolute",
          left: p.x + "%",
          top: "-20px",
          width: p.size,
          height: p.size * 0.6,
          background: p.color,
          borderRadius: 2,
          animation: `confettiFall ${p.dur}s ${p.delay}s ease-in forwards`,
          transform: `rotate(${p.rotate}deg)`,
        }}/>
      ))}
      <style>{`
        @keyframes confettiFall {
          0%   { transform: translateY(0) translateX(0) rotate(0deg); opacity:1; }
          100% { transform: translateY(100vh) translateX(${60}px) rotate(720deg); opacity:0; }
        }
      `}</style>
    </div>
  );
}

// ─── Animated tile reveal (bounces into correct order) ────────────────────────
function AnimatedWordReveal({ word, active }) {
  const [step, setStep] = useState(-1);
  useEffect(() => {
    if (!active) { setStep(-1); return; }
    setStep(0);
    let i = 0;
    const iv = setInterval(() => {
      i++;
      setStep(i);
      if (i >= word.length) clearInterval(iv);
    }, 160);
    return () => clearInterval(iv);
  }, [active, word]);

  return (
    <div style={{ display:"flex", gap:6, justifyContent:"center", flexWrap:"nowrap" }}>
      {word.split("").map((l, i) => {
        const revealed = step > i;
        return (
          <div key={i} style={{
            width: word.length > 6 ? 38 : 50,
            height: word.length > 6 ? 46 : 58,
            background: revealed ? LOGO_GREEN : C.surface,
            border: "2.5px solid " + (revealed ? LOGO_GREEN : C.border),
            borderRadius: 10, display:"flex", alignItems:"center", justifyContent:"center",
            fontSize: word.length > 6 ? 19 : 25, fontWeight:900,
            color: revealed ? C.white : "transparent",
            fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
            flexShrink:0,
            transform: revealed ? "translateY(0) scale(1)" : "translateY(-8px) scale(0.85)",
            transition: "all 0.25s cubic-bezier(0.34,1.56,0.64,1)",
            boxShadow: revealed ? "0 4px 10px rgba(45,106,79,0.3)" : "none",
          }}>
            {revealed ? l : ""}
          </div>
        );
      })}
    </div>
  );
}

// ─── DiffPill ─────────────────────────────────────────────────────────────────
function DiffPill({ diff, session }) {
  const played = session.played.includes(diff);
  const isFirst = session.firstDiff === diff;
  const won = isFirst && session.firstSuccess;
  const lost = isFirst && session.firstSuccess === false;
  const diffGreen = { 5: C.forest5, 6: C.forest6, 7: C.forest7 }[diff];
  const bg = won ? C.teal : lost ? "#F08050" : played ? C.surface : diffGreen || C.white;
  const border = won ? C.teal : lost ? "#F08050" : played ? C.border : diffGreen || C.border;
  const textColor = won||lost ? C.white : played ? C.muted : C.white;
  return (
    <div style={{
      display:"flex", flexDirection:"column", alignItems:"center",
      background:bg, border:"2px solid "+border, borderRadius:14,
      padding:"10px 14px", gap:2, minWidth:60,
      boxShadow:"0 2px 8px #00000010",
    }}>
      <span style={{ fontSize:20, fontWeight:900, color:textColor, fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif" }}>{diff}</span>
      <span style={{ fontSize:10, color:textColor, opacity:0.8, fontWeight:600 }}>
        {won ? <IconCheck size={13} color={C.white}/> : lost ? "✗" : played ? "done" : `${POINTS[diff]}pt`}
      </span>
    </div>
  );
}

// ─── Btn helper ───────────────────────────────────────────────────────────────
function Btn({ children, onClick, variant="primary", style:extra={} }) {
  const variants = {
    primary:   { background:C.coral,   color:C.white,   border:"none" },
    secondary: { background:C.surface, color:C.ink,     border:"2px solid "+C.border },
    teal:      { background:C.teal,    color:C.white,   border:"none" },
    ghost:     { background:"transparent", color:C.muted, border:"none" },
    outline:   { background:C.white,   color:C.coral,   border:"2px solid "+C.coral },
  };
  return (
    <button onClick={onClick} style={{
      ...variants[variant],
      borderRadius:14, fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif", fontWeight:700,
      fontSize:16, padding:"14px 28px", cursor:"pointer",
      boxShadow: variant==="primary" ? "0 4px 16px #F4623A44" : "none",
      transition:"opacity 0.15s, transform 0.1s",
      ...extra,
    }}
    onMouseOver={e=>e.currentTarget.style.opacity="0.88"}
    onMouseOut={e=>e.currentTarget.style.opacity="1"}
    >{children}</button>
  );
}

// ─── Page shell ───────────────────────────────────────────────────────────────
function Page({ children, center=true }) {
  return (
    <div style={{
      minHeight:"100vh", background:C.cream,
      display:"flex", flexDirection:"column",
      alignItems:"center", justifyContent: center ? "center" : "flex-start",
      padding:"28px 20px", fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
      boxSizing:"border-box",
    }}>{children}</div>
  );
}

function Card({ children, style:extra={} }) {
  return (
    <div style={{
      background:C.white, borderRadius:20, padding:"22px 24px",
      border:"1.5px solid "+C.border, boxShadow:"0 4px 20px #00000010",
      width:"100%", maxWidth:360, boxSizing:"border-box",
      ...extra,
    }}>{children}</div>
  );
}

// ─── Main ─────────────────────────────────────────────────────────────────────
export default function AlteredGame() {
  // ── Core state ──────────────────────────────────────────────────────────
  const [screen, setScreen]       = useState("home");
  const [difficulty, setDiff]     = useState(null);
  const [word, setWord]           = useState("");
  const [jumbled, setJumbled]     = useState("");
  const [timeLeft, setTimeLeft]   = useState(8);
  const [stopped, setStopped]     = useState(false);
  const [guess, setGuess]         = useState("");
  const [outcome, setOutcome]     = useState(null); // "correct"|"wrong"|"timeout"
  const [revealed, setRevealed]   = useState(false);
  const [revealAnim, setRevealAnim] = useState(false);
  const [celebrating, setCelebrating] = useState(false);
  const [isPractice, setIsPractice] = useState(false);
  const [stats, setStats]         = useState(loadStats);
  const [session, setSession]     = useState(loadTodaySession);

  const timerRef  = useRef(null);
  const inputRef  = useRef(null);

  // ── Practice sets ───────────────────────────────────────────────────────
  const PRACTICE_SETS = {
    4: ["GLOW","WRAP","JUMP"],
    5: ["STORM","BRAVE","PLUMB"],
    6: ["CASTLE","BRIDGE","ZEPHYR"],
    7: ["LANTERN","MYSTERY","PILGRIM"],
  };

  // ── Derived climb state ─────────────────────────────────────────────────
  const currentLevel   = session.climbLevel || 4;       // next level to play
  const bankedPoints   = session.bankedPoints || 0;
  const busted         = session.busted || false;
  const climbComplete  = session.completed || false;
  const funPlayed      = session.funPlayed || [];
  const totalPossible  = POINTS[4]+POINTS[5]+POINTS[6]+POINTS[7]; // 22
  const levelsDone     = LEVELS.filter(l => l < currentLevel);    // completed levels
  const cumulativeAtLevel = (lvl) => LEVELS.filter(l => l <= lvl).reduce((s,l) => s+POINTS[l], 0);

  // ── Start a real game level ─────────────────────────────────────────────
  const startLevel = useCallback((diff) => {
    const chosen = getDailyWord(diff);
    setDiff(diff); setWord(chosen); setJumbled(scramble(chosen));
    setTimeLeft(CLOCK[diff]); setStopped(false);
    setGuess(""); setOutcome(null); setRevealed(false);
    setRevealAnim(false); setCelebrating(false);
    setIsPractice(false);
    setScreen("game");
  }, []);

  // ── Start a practice round ──────────────────────────────────────────────
  const startPractice = useCallback((diff = 4) => {
    const idx = session.practiceIdx?.[diff] || 0;
    const sets = PRACTICE_SETS[diff];
    if (idx >= sets.length) { setScreen("practicelimit"); return; }
    const chosen = sets[idx];
    setDiff(diff); setWord(chosen); setJumbled(scramble(chosen));
    setTimeLeft(CLOCK[diff]); setStopped(false);
    setGuess(""); setOutcome(null); setRevealed(false);
    setRevealAnim(false); setCelebrating(false);
    setIsPractice(true);
    setScreen("game");
  }, [session]);

  // ── Countdown ───────────────────────────────────────────────────────────
  useEffect(() => {
    if (screen !== "game" || stopped) return;
    if (timeLeft <= 0) { handleFinish("timeout"); return; }
    timerRef.current = setTimeout(() => setTimeLeft(t => t-1), 1000);
    return () => clearTimeout(timerRef.current);
  }, [screen, stopped, timeLeft]);

  useEffect(() => {
    if (screen === "typing" && inputRef.current) inputRef.current.focus();
  }, [screen]);

  function handleStop() {
    clearTimeout(timerRef.current);
    setStopped(true);
    setScreen("typing");
  }

  function handleGuessSubmit() {
    handleFinish(guess.trim().toUpperCase() === word ? "correct" : "wrong");
  }

  // ── Core finish logic ───────────────────────────────────────────────────
  function handleFinish(result) {
    const correct = result === "correct";
    setOutcome(result);

    // Practice: just increment counter and show result
    if (isPractice) {
      const ns = { ...session };
      ns.practiceIdx = { ...(ns.practiceIdx || {4:0,5:0,6:0,7:0}) };
      ns.practiceIdx[difficulty] = (ns.practiceIdx[difficulty] || 0) + 1;
      saveTodaySession(ns); setSession(ns);
      setScreen("result");
      return;
    }

    const ns = { ...session };

    if (correct) {
      // Solved — celebrate, update streak
      setCelebrating(true);
      setTimeout(() => setCelebrating(false), 2400);
      const today = getDayKey();
      const yesterday = new Date(Date.now()-86400000).toISOString().split("T")[0];
      const newStats = { ...stats };
      if (newStats.lastDay !== today) {
        newStats.streak = newStats.lastDay === yesterday ? (newStats.streak||0)+1 : 1;
        newStats.lastDay = today;
      }
      // Move to next level (don\'t bank yet — player chooses)
      ns.climbLevel = difficulty + 1;
      if (difficulty === 7) {
        // Completed the whole climb!
        ns.bankedPoints = cumulativeAtLevel(7);
        ns.completed = true;
        newStats.totalScore = (newStats.totalScore||0) + ns.bankedPoints;
        newStats.diffCounts = { ...(newStats.diffCounts||{4:0,5:0,6:0,7:0}) };
        newStats.diffCounts[7] = (newStats.diffCounts[7]||0) + 1;
        saveStats(newStats); setStats(newStats);
      }
      saveStats(newStats); setStats(newStats);
    } else {
      // Busted — lose all points, keep streak (streak updated on first correct)
      ns.busted = true;
      ns.bankedPoints = 0;
    }

    saveTodaySession(ns); setSession(ns);
    setScreen("result");
  }

  // ── Bank points and stop climbing ───────────────────────────────────────
  function handleBank() {
    const earned = cumulativeAtLevel(difficulty);
    const ns = { ...session };
    ns.bankedPoints = earned;
    ns.completed = true; // done climbing for today

    const newStats = { ...stats };
    newStats.totalScore = (newStats.totalScore||0) + earned;
    newStats.diffCounts = { ...(newStats.diffCounts||{4:0,5:0,6:0,7:0}) };
    newStats.diffCounts[difficulty] = (newStats.diffCounts[difficulty]||0) + 1;
    saveStats(newStats); setStats(newStats);
    saveTodaySession(ns); setSession(ns);
    setScreen("banked");
  }

  // ── Play remaining levels for fun ───────────────────────────────────────
  function startFun(diff) {
    const chosen = getDailyWord(diff);
    setDiff(diff); setWord(chosen); setJumbled(scramble(chosen));
    setTimeLeft(CLOCK[diff]); setStopped(false);
    setGuess(""); setOutcome(null); setRevealed(false);
    setRevealAnim(false); setCelebrating(false);
    setIsPractice(false);
    setScreen("game_fun");
  }

  const tileSize = difficulty >= 7 ? "sm" : difficulty === 6 ? "sm" : "md";
  const remainingFun = LEVELS.filter(l => l > (busted ? currentLevel-1 : difficulty || currentLevel-1) && !funPlayed.includes(l));

  // ── Shared tile row ─────────────────────────────────────────────────────
  function TileRow({ word: w, size }) {
    const sz = size || (w?.length >= 7 ? "sm" : w?.length === 6 ? "sm" : "md");
    return (
      <div style={{ display:"flex", gap:sz==="sm"?5:8, flexWrap:"nowrap", justifyContent:"center" }}>
        {(w||"").split("").map((l,i) => <LetterTile key={i} letter={l} size={sz}/>)}
      </div>
    );
  }

  // ── Climb progress bar ─────────────────────────────────────────────────
  function ClimbBar({ currentDiff, banked, busted: isBusted }) {
    return (
      <div style={{ width:"100%", maxWidth:360, margin:"0 auto" }}>
        <div style={{ display:"flex", gap:8, justifyContent:"center", alignItems:"flex-end" }}>
          {LEVELS.map((lvl, i) => {
            const done   = lvl < (currentDiff || currentLevel);
            const active = lvl === (currentDiff || currentLevel) && !isBusted;
            const lost   = isBusted && lvl >= currentLevel;
            const tileColor = done ? C.teal : active ? C.coral : lost ? "#E0C0B8" : C.surface;
            const textColor = done || active ? C.white : lost ? "#C09090" : C.muted;
            const shadow = done
              ? "0 3px 8px rgba(78,203,166,0.35), 0 1px 3px rgba(0,0,0,0.10)"
              : active
              ? "0 4px 12px rgba(244,98,58,0.35), 0 2px 4px rgba(0,0,0,0.12)"
              : "0 2px 4px rgba(0,0,0,0.07)";

            return (
              <div key={lvl} style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", gap:6 }}>
                {/* Tile */}
                <div style={{
                  width:"100%", maxWidth:72,
                  background: tileColor,
                  borderRadius:10,
                  padding:"8px 4px 6px",
                  boxShadow: shadow,
                  transition:"background 0.35s, box-shadow 0.35s",
                  textAlign:"center",
                }}>
                  <div style={{
                    fontSize:20, fontWeight:900, color:textColor, lineHeight:1,
                    fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
                  }}>{lvl}</div>
                  <div style={{
                    fontSize:9, fontWeight:700, color:textColor, opacity:0.85,
                    marginTop:3, letterSpacing:0.3,
                    fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
                    lineHeight:1.3,
                  }}>letter<br/>word</div>
                </div>
                {/* Points label below tile */}
                <div style={{
                  fontSize:10, fontWeight:700,
                  color: done ? C.teal : active ? C.coral : C.muted,
                }}>
                  {POINTS[lvl]}pt
                </div>
              </div>
            );
          })}
        </div>
      </div>
    );
  }

  // ════════════════════════════════════════════════════════════════════════
  // SCREENS
  // ════════════════════════════════════════════════════════════════════════

  // ── PRACTICE LIMIT ──────────────────────────────────────────────────────
  if (screen === "practicelimit") return (
    <Page>
      <AlteredLogo size="md"/>
      <div style={{ marginTop:20, marginBottom:10 }}><IconStop size={52}/></div>
      <h2 style={{ color:C.ink, fontSize:20, margin:"0 0 8px", fontWeight:800 }}>That's all the practice for today!</h2>
      <p style={{ color:C.muted, fontSize:13, textAlign:"center", maxWidth:270, lineHeight:1.6, margin:"0 0 20px" }}>
        You've used all 3 practice rounds. Come back tomorrow for fresh ones — or jump into the real game!
      </p>
      <div style={{ display:"flex", gap:10 }}>
        <Btn onClick={() => setScreen("home")} variant="primary">Play for real →</Btn>
        <Btn onClick={() => setScreen("home")} variant="ghost">Home</Btn>
      </div>
    </Page>
  );

  // ── HOME ────────────────────────────────────────────────────────────────
  if (screen === "home") {
    const canClimb = !busted && !climbComplete && currentLevel <= 7;
    return (
      <Page>
        <div style={{ marginBottom:8 }}><AlteredLogo size="lg"/></div>
        <p style={{ color:C.muted, fontSize:14, margin:"8px 0 20px", textAlign:"center", lineHeight:1.6, maxWidth:280 }}>
          Unscramble the word. Climb the ladder.<br/>Bank your points — or risk it all.
        </p>

        {/* Climb progress */}
        <div style={{ width:"100%", maxWidth:340, marginBottom:20 }}>
          <ClimbBar currentDiff={currentLevel} banked={bankedPoints} busted={busted}/>
        </div>

        {/* Status card */}
        {(busted || climbComplete || levelsDone.length > 0) && (
          <Card style={{ marginBottom:16, textAlign:"center" }}>
            {climbComplete && !busted && (
              <>
                <div style={{ color:C.teal, fontWeight:800, fontSize:16 }}>
                  {bankedPoints === totalPossible ? "Perfect score! 🎯" : `Banked ${bankedPoints} points today`}
                </div>
                <div style={{ color:C.muted, fontSize:12, marginTop:4 }}>
                  {bankedPoints === totalPossible ? "You conquered the full ladder!" : `Stopped at the ${difficulty || currentLevel-1}-worder`}
                </div>
              </>
            )}
            {busted && (
              <>
                <div style={{ color:C.red, fontWeight:800, fontSize:16 }}>Busted! 0 points today</div>
                <div style={{ color:C.muted, fontSize:12, marginTop:4 }}>You fell on the {currentLevel}-worder</div>
              </>
            )}
            {!busted && !climbComplete && levelsDone.length > 0 && (
              <>
                <div style={{ color:C.coral, fontWeight:800, fontSize:15 }}>
                  {cumulativeAtLevel(currentLevel-1)} pts banked — keep climbing?
                </div>
                <div style={{ color:C.muted, fontSize:12, marginTop:4 }}>Next: {currentLevel}-worder worth {POINTS[currentLevel]} more pts</div>
              </>
            )}
          </Card>
        )}

        {canClimb && (
          <button onClick={() => startLevel(currentLevel)} style={{
            background: C.forestPlay, color: C.white, border:"none",
            borderRadius:14, fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
            fontWeight:700, fontSize:18, padding:"16px 48px", cursor:"pointer",
            boxShadow:"0 5px 14px rgba(0,0,0,0.13), 0 2px 4px rgba(0,0,0,0.08)",
          }}>
            {currentLevel === 4 ? "Start today's climb" : `Climb to ${currentLevel}-worder →`}
          </button>
        )}

        {!canClimb && remainingFun.length > 0 && (
          <div style={{ display:"flex", gap:8, flexWrap:"wrap", justifyContent:"center" }}>
            {remainingFun.map(d => (
              <button key={d} onClick={() => startFun(d)} style={{
                background:C.surface, border:"1.5px solid "+C.border, borderRadius:12,
                padding:"10px 20px", cursor:"pointer", fontSize:14, fontWeight:700,
                color:C.muted, fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
              }}>
                Try {d}-worder (for fun)
              </button>
            ))}
          </div>
        )}

        <div style={{ display:"flex", gap:10, marginTop:16 }}>
          <Btn onClick={() => setScreen("howtoplay")} variant="secondary" style={{ fontSize:13, padding:"10px 18px" }}>How to play</Btn>
          <Btn onClick={() => { const d = LEVELS.find(l => (session.practiceIdx?.[l]||0) < 3) || 4; startPractice(d); }}
            variant="secondary" style={{ fontSize:13, padding:"10px 18px" }}>
            Practice
          </Btn>
        </div>
        <Btn onClick={() => setScreen("stats")} variant="ghost" style={{ marginTop:8, fontSize:13 }}>My stats →</Btn>

        {/* Dev reset */}
        <div onClick={() => {
          localStorage.removeItem("altered_session_" + getDayKey());
          setSession({ bankedPoints:0, climbLevel:4, busted:false, completed:false, funPlayed:[], practiceIdx:{4:0,5:0,6:0,7:0} });
        }} style={{ marginTop:36, fontSize:11, color:C.border, cursor:"pointer", userSelect:"none" }}>
          reset today
        </div>
      </Page>
    );
  }

  // ── HOW TO PLAY ─────────────────────────────────────────────────────────
  if (screen === "howtoplay") return (
    <Page center={false}>
      <div style={{ width:"100%", maxWidth:380 }}>
        <div style={{ display:"flex", justifyContent:"center", marginBottom:16, marginTop:8 }}>
          <AlteredLogo size="md"/>
        </div>
        <h2 style={{ textAlign:"center", color:C.ink, fontSize:20, margin:"0 0 20px", fontWeight:800 }}>How to play</h2>
        <div style={{ display:"flex", flexDirection:"column", gap:12 }}>
          {[
            { icon:<IconTarget size={36}/>, title:"Start at the bottom", body:"Everyone begins with a 4-worder. Solve it to climb to 5, then 6, then 7. You must play in order." },
            { icon:<IconShuffle size={36}/>, title:"Unscramble the word", body:"The letters of a real word are jumbled on screen. The clock counts down — study the letters quickly!" },
            { icon:<IconStop size={36}/>, title:"Hit GUESS when you know it", body:"Tap GUESS to freeze the clock, then type your answer. No typing timer — take a breath." },
            { icon:<IconStar size={36}/>, title:"Bank or climb", body:"Solve a level and choose: bank your points safely, or risk them all climbing to the next level." },
            { icon:<IconKeyboard size={36}/>, title:"Bust and lose it all", body:"Fail at any level and you lose all points for the day — but your streak stays safe. Come back tomorrow!" },
          ].map((step, i) => (
            <div key={i} style={{ background:C.white, border:"1.5px solid "+C.border, borderRadius:14,
              padding:"14px 16px", display:"flex", gap:14, alignItems:"flex-start",
              boxShadow:"0 2px 8px #00000008" }}>
              {step.icon}
              <div>
                <div style={{ fontWeight:800, fontSize:14, color:C.ink, marginBottom:4 }}>{step.title}</div>
                <div style={{ fontSize:13, color:C.muted, lineHeight:1.5 }}>{step.body}</div>
              </div>
            </div>
          ))}
        </div>
        <div style={{ display:"flex", gap:10, marginTop:20, justifyContent:"center" }}>
          <Btn onClick={() => startPractice(4)} variant="primary" style={{ fontSize:14 }}>Try a practice round</Btn>
          <Btn onClick={() => setScreen("home")} variant="secondary" style={{ fontSize:14 }}>Got it!</Btn>
        </div>
      </div>
    </Page>
  );

  // ── GAME (real climb) ────────────────────────────────────────────────────
  if (screen === "game" || screen === "game_fun") {
    const isFun = screen === "game_fun";
    const sz = difficulty >= 6 ? "sm" : "md";
    return (
      <Page>
        <AlteredLogo size="sm"/>
        <div style={{ marginTop:16, marginBottom:4, width:"100%", maxWidth:340 }}>
          <ClimbBar currentDiff={difficulty} banked={bankedPoints} busted={false}/>
        </div>
        <div style={{ display:"flex", gap:8, margin:"12px 0 24px", justifyContent:"center" }}>
          <span style={{ background:C.surface, borderRadius:20, padding:"4px 14px", fontSize:12, color:C.muted, fontWeight:700 }}>
            {difficulty} letters
          </span>
          <span style={{ background: isFun ? C.surface : C.coral, borderRadius:20, padding:"4px 14px",
            fontSize:12, color: isFun ? C.muted : C.white, fontWeight:700 }}>
            {isFun ? "for fun" : isPractice ? "practice" : `${POINTS[difficulty]} pts on the line`}
          </span>
        </div>

        <div style={{ display:"flex", gap:difficulty>=6?5:8, flexWrap:"nowrap", justifyContent:"center", marginBottom:32 }}>
          {jumbled.split("").map((l,i) => <LetterTile key={i} letter={l} size={sz}/>)}
        </div>

        <ClockRing timeLeft={timeLeft} total={CLOCK[difficulty]}/>

        <Btn onClick={handleStop} variant="primary" style={{ marginTop:22, fontSize:22, padding:"18px 60px", borderRadius:18, letterSpacing:1 }}>
          GUESS
        </Btn>
        <p style={{ color:C.muted, fontSize:12, marginTop:12 }}>Tap GUESS when you know the answer</p>
      </Page>
    );
  }

  // ── TYPING ──────────────────────────────────────────────────────────────
  if (screen === "typing") {
    const sz = difficulty >= 6 ? "sm" : "md";
    return (
      <Page>
        <AlteredLogo size="sm"/>
        <p style={{ color:C.coral, fontSize:13, fontWeight:700, letterSpacing:2, textTransform:"uppercase", margin:"18px 0 8px" }}>
          What's the word?
        </p>
        <p style={{ color:C.muted, fontSize:12, marginBottom:28 }}>{difficulty} letters</p>
        <div style={{ display:"flex", gap:difficulty>=6?5:8, flexWrap:"nowrap", justifyContent:"center", marginBottom:28 }}>
          {Array.from({length:difficulty}).map((_,i) => (
            <div key={i} style={{
              width: sz==="sm"?38:50, height:sz==="sm"?46:58,
              background:C.surface, border:"2.5px dashed "+C.border, borderRadius:10, flexShrink:0,
            }}/>
          ))}
        </div>
        <input ref={inputRef} value={guess}
          onChange={e => setGuess(e.target.value.toUpperCase())}
          onKeyDown={e => { if(e.key==="Enter") handleGuessSubmit(); }}
          maxLength={difficulty} placeholder="Type here…"
          style={{
            background:C.white, border:"2.5px solid "+C.coral, borderRadius:14,
            color:C.ink, fontSize:28, fontWeight:900, textAlign:"center",
            padding:"14px 16px", width:240, outline:"none",
            fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif", letterSpacing:4,
            boxShadow:"0 4px 16px rgba(244,98,58,0.15)",
          }}
        />
        <Btn onClick={handleGuessSubmit} variant="primary" style={{ marginTop:18, padding:"14px 48px", fontSize:17 }}>Submit</Btn>
        <button onClick={() => setScreen("game")} style={{
          background:"none", border:"none", color:C.muted, fontSize:12,
          marginTop:12, cursor:"pointer", fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
        }}>← back to word</button>
      </Page>
    );
  }

  // ── RESULT ──────────────────────────────────────────────────────────────
  if (screen === "result") {
    const correct = outcome === "correct";
    const timedOut = outcome === "timeout";
    const isFunRound = screen === "result" && funPlayed.includes(difficulty);
    const runningTotal = correct && !isPractice ? cumulativeAtLevel(difficulty) : bankedPoints;
    const nextLevel = difficulty + 1;
    const hasNextLevel = nextLevel <= 7 && correct && !isPractice;

    return (
      <Page>
        <Confetti active={celebrating && correct}/>
        <AlteredLogo size="sm"/>
        <div style={{ margin:"16px 0 8px" }}>
          {correct ? <IconWin size={60}/> : timedOut ? <IconTimeout size={60}/> : <IconWrong size={60}/>}
        </div>
        <div style={{ fontSize:22, fontWeight:800, color:correct?C.teal:C.coral, marginBottom:4 }}>
          {correct ? (difficulty===7 && !isPractice ? "You conquered it all!" : "Solved it!") : timedOut ? "Time's up!" : "Not quite!"}
        </div>

        {isPractice && <p style={{ color:C.muted, fontSize:13, margin:"2px 0 16px" }}>Practice round — no points</p>}

        {!isPractice && correct && (
          <div style={{ background:C.teal+"18", border:"1.5px solid "+C.teal+"44", borderRadius:12,
            padding:"10px 20px", textAlign:"center", marginBottom:16 }}>
            <div style={{ color:C.teal, fontWeight:800, fontSize:15 }}>
              +{POINTS[difficulty]} pts → {runningTotal} pts total
            </div>
            {difficulty < 7 && <div style={{ color:C.muted, fontSize:12, marginTop:2 }}>Keep going for {POINTS[nextLevel]} more pts</div>}
          </div>
        )}

        {!isPractice && !correct && !session.completed && (
          <div style={{ background:C.red+"15", border:"1.5px solid "+C.red+"44", borderRadius:12,
            padding:"10px 20px", textAlign:"center", marginBottom:16 }}>
            <div style={{ color:C.red, fontWeight:800, fontSize:15 }}>Busted! All points lost</div>
            <div style={{ color:C.muted, fontSize:12, marginTop:2 }}>Your streak is safe — come back tomorrow</div>
          </div>
        )}

        {/* Reveal section on wrong */}
        {!correct && (
          <Card style={{ marginBottom:16 }}>
            <p style={{ color:C.muted, fontSize:12, margin:"0 0 10px", textAlign:"center" }}>The altered was:</p>
            <div style={{ display:"flex", gap:difficulty>=6?4:6, justifyContent:"center", marginBottom:12, flexWrap:"nowrap" }}>
              {jumbled.split("").map((l,i) => <LetterTile key={i} letter={l} revealed={revealed} size={difficulty>=6?"sm":"md"}/>)}
            </div>
            {revealed
              ? <AnimatedWordReveal word={word} active={revealAnim}/>
              : <div style={{ display:"flex", gap:10, justifyContent:"center" }}>
                  <Btn variant="secondary" onClick={() => { setGuess(""); setScreen("typing"); }} style={{ fontSize:13, padding:"10px 16px" }}>Keep trying…</Btn>
                  <Btn variant="outline" onClick={() => { setRevealed(true); setRevealAnim(true); }} style={{ fontSize:13, padding:"10px 16px" }}>Reveal</Btn>
                </div>
            }
          </Card>
        )}

        {/* Bank or Climb decision — only when correct on a real game */}
        {!isPractice && correct && difficulty < 7 && (
          <Card style={{ marginBottom:16 }}>
            <p style={{ color:C.ink, fontWeight:800, fontSize:14, margin:"0 0 6px", textAlign:"center" }}>
              You've got {runningTotal} pts banked. What do you do?
            </p>
            <p style={{ color:C.muted, fontSize:12, margin:"0 0 14px", textAlign:"center" }}>
              Fail the next level and you lose everything.
            </p>
            <div style={{ display:"flex", gap:10, justifyContent:"center" }}>
              <Btn onClick={handleBank} variant="teal" style={{ fontSize:14, padding:"12px 20px" }}>
                Bank {runningTotal} pts ✓
              </Btn>
              <Btn onClick={() => startLevel(nextLevel)} variant="primary" style={{ fontSize:14, padding:"12px 20px" }}>
                Risk it! {nextLevel}-worder →
              </Btn>
            </div>
          </Card>
        )}

        {/* Practice next round */}
        {isPractice && (
          <div style={{ display:"flex", gap:10, marginTop:4 }}>
            {(session.practiceIdx?.[difficulty]||0) < 3
              ? <Btn onClick={() => startPractice(difficulty)} variant="teal" style={{ fontSize:14, padding:"12px 20px" }}>
                  Next practice ({3-(session.practiceIdx?.[difficulty]||0)} left)
                </Btn>
              : <div style={{ color:C.muted, fontSize:13, padding:"10px 0" }}>No more practice today</div>
            }
            <Btn onClick={() => setScreen("home")} variant="primary" style={{ fontSize:14, padding:"12px 20px" }}>Play for real →</Btn>
          </div>
        )}

        <div style={{ display:"flex", gap:10, marginTop:16 }}>
          <Btn onClick={() => setScreen("stats")} variant="teal" style={{ fontSize:14, padding:"12px 20px" }}>Stats</Btn>
          <Btn onClick={() => setScreen("home")} variant="secondary" style={{ fontSize:14, padding:"12px 20px" }}>Home</Btn>
        </div>
      </Page>
    );
  }

  // ── BANKED ──────────────────────────────────────────────────────────────
  if (screen === "banked") {
    const remaining = LEVELS.filter(l => l > difficulty);
    return (
      <Page>
        <Confetti active={true}/>
        <AlteredLogo size="sm"/>
        <div style={{ margin:"20px 0 10px" }}><IconWin size={64}/></div>
        <h2 style={{ color:C.teal, fontSize:24, fontWeight:800, margin:"0 0 6px" }}>Points banked!</h2>
        <div style={{ fontSize:48, fontWeight:900, color:C.ink, margin:"8px 0 4px", fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif" }}>
          {bankedPoints || cumulativeAtLevel(difficulty)}
        </div>
        <div style={{ color:C.muted, fontSize:14, marginBottom:20 }}>points secured for today</div>

        <ClimbBar currentDiff={difficulty} banked={bankedPoints} busted={false}/>

        {remaining.length > 0 && (
          <Card style={{ marginTop:20, textAlign:"center" }}>
            <p style={{ color:C.muted, fontSize:13, margin:"0 0 12px" }}>
              Play the rest for fun? No points on the line.
            </p>
            <div style={{ display:"flex", gap:8, justifyContent:"center", flexWrap:"wrap" }}>
              {remaining.map(d => (
                <button key={d} onClick={() => startFun(d)} style={{
                  background:C.surface, border:"1.5px solid "+C.border, borderRadius:10,
                  padding:"10px 18px", cursor:"pointer", fontSize:14, fontWeight:700,
                  color:C.ink, fontFamily:"'Helvetica Neue', Helvetica, Arial, sans-serif",
                }}>
                  {d}-worder
                </button>
              ))}
            </div>
          </Card>
        )}

        <div style={{ display:"flex", gap:10, marginTop:20 }}>
          <Btn onClick={() => setScreen("stats")} variant="teal" style={{ fontSize:14, padding:"12px 20px" }}>Stats</Btn>
          <Btn onClick={() => setScreen("home")} variant="secondary" style={{ fontSize:14, padding:"12px 20px" }}>Home</Btn>
        </div>
      </Page>
    );
  }

  // ── STATS ───────────────────────────────────────────────────────────────
  if (screen === "stats") {
    const dc = stats.diffCounts || {4:0,5:0,6:0,7:0};
    const total = Math.max(Object.values(dc).reduce((a,b)=>a+b,0), 1);
    const barColors = { 4:C.teal, 5:C.forest5, 6:C.forest6, 7:C.forest7 };
    return (
      <Page center={false}>
        <div style={{ display:"flex", flexDirection:"column", alignItems:"center", width:"100%", maxWidth:380 }}>
          <div style={{ margin:"8px 0 6px" }}><AlteredLogo size="md"/></div>
          <p style={{ color:C.muted, fontSize:13, margin:"0 0 24px" }}>Your puzzle history</p>
          <div style={{ display:"flex", gap:12, marginBottom:18, width:"100%" }}>
            {[
              { label:"Total Score", val:stats.totalScore||0, unit:"pts", color:C.coral },
              { label:"Win Streak",  val:stats.streak||0,      unit:"days", color:C.teal },
            ].map(s => (
              <div key={s.label} style={{ flex:1, background:C.white, borderRadius:16, padding:"18px 12px",
                textAlign:"center", border:"1.5px solid "+C.border, boxShadow:"0 2px 10px #00000010" }}>
                <div style={{ fontSize:36, fontWeight:900, color:s.color }}>{s.val}</div>
                <div style={{ fontSize:11, color:C.muted, marginTop:2 }}>{s.unit}</div>
                <div style={{ fontSize:11, color:C.muted, marginTop:4, fontWeight:600 }}>{s.label}</div>
              </div>
            ))}
          </div>
          <Card>
            <p style={{ color:C.muted, fontSize:11, margin:"0 0 14px", letterSpacing:2, textTransform:"uppercase", fontWeight:700 }}>
              Highest level reached
            </p>
            {LEVELS.map(d => (
              <div key={d} style={{ marginBottom:12 }}>
                <div style={{ display:"flex", justifyContent:"space-between", marginBottom:5 }}>
                  <span style={{ color:C.ink, fontSize:13, fontWeight:700 }}>{d} worder <span style={{ color:C.muted, fontWeight:400 }}>· {POINTS[d]}pt</span></span>
                  <span style={{ color:barColors[d], fontSize:13, fontWeight:800 }}>{dc[d]||0}</span>
                </div>
                <div style={{ height:7, background:C.surface, borderRadius:4 }}>
                  <div style={{ height:7, background:barColors[d], borderRadius:4, width:((dc[d]||0)/total*100)+"%", transition:"width 0.6s" }}/>
                </div>
              </div>
            ))}
          </Card>
          <Btn onClick={() => setScreen("home")} variant="ghost" style={{ marginTop:20, fontSize:13 }}>← Back to home</Btn>
        </div>
      </Page>
    );
  }

  return null;
}
